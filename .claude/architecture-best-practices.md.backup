│       ├── SaveFocusStrategyUseCase.kt
│       ├── DeleteFocusStrategyUseCase.kt
│       ├── ToggleStrategyActiveUseCase.kt
│       └── GetInstalledAppsUseCase.kt
│
├── data/                            # 数据层
│   ├── local/                       # 本地数据源
│   │   ├── entity/                  # Room 实体
│   │   │   └── FocusStrategyEntity.kt
│   │   │
│   │   ├── dao/                     # 数据访问对象
│   │   │   └── FocusStrategyDao.kt
│   │   │
│   │   └── database/                # 数据库
│   │       └── FocusDatabase.kt
│   │
│   └── repository/                  # 仓库实现
│       └── FocusRepositoryImpl.kt
│
├── presentation/                    # 表现层
